# Copy to .env and fill in. Loaded by src/grounded/config.py::load_dotenv().
# .env itself is gitignored.

# Semantic Scholar (raises rate limit to 10 req/sec; free tier still works without it)
S2_API_KEY=

# Local weights (rsync'd from home machine; see docs/OFFLINE_MODEL_TRANSFER.md)
# GROUNDED_MODELS_ROOT=/data/team1/models

# Hugging Face token (metadata only when weights are local; required for Hub fallback)
HF_TOKEN=

# Weights & Biases (logging dashboard; runs/ JSON is the source of truth)
WANDB_API_KEY=

# AWS — NOT required after v3.1 (S3 budget closed). Leave blank.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
