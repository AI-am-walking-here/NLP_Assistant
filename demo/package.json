{
  "name": "grounded-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:api": "bash scripts/start-api.sh",
    "dev:api:mock": "GROUNDED_DEMO_MOCK=1 GROUNDED_DEMO_EMBED_DEVICE=${GROUNDED_DEMO_EMBED_DEVICE:-cpu} bash scripts/start-api.sh",
    "dev:api:fast": "GROUNDED_DEMO_FAST=1 bash scripts/start-api.sh",
    "dev:web": "bash scripts/wait-for-api.sh && bash scripts/env-node.sh env NEXT_PUBLIC_GROUNDED_API_URL=http://127.0.0.1:8080 next dev --hostname 0.0.0.0",
    "dev": "bash scripts/run-dev.sh",
    "dev:mock": "GROUNDED_DEMO_MOCK=1 bash scripts/run-dev.sh",
    "dev:fast": "GROUNDED_DEMO_FAST=1 bash scripts/run-dev.sh",
    "build": "bash scripts/env-node.sh next build",
    "start": "bash scripts/env-node.sh next start",
    "lint": "bash scripts/env-node.sh next lint"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2"
  }
}
